{
  "private": true,
  "name": "bloumechat-desktop",
  "description": "Bloumechat Desktop Application",
  "version": "2.10.0",
  "author": "Bloumechat <contact@bloume.fr>",
  "main": "app/background.js",
  "scripts": {
    "start": "nextron --renderer-port 8899",
    "dev": "nextron --renderer-port 8899",
    "build": "npm run build:exe",
    "build:exe": "node -e \"require('dotenv').config(); require('child_process').spawn('npx', ['nextron', 'build', '--win', 'nsis'], {stdio: 'inherit', shell: true})\"",
    "build:msix": "npx nextron build --win appx",
    "build:mac": "nextron build --mac",
    "build:mac:universal": "nextron build --mac --universal",
    "build:linux": "nextron build --linux",
    "build:all": "npm run build:exe && npm run build:msix && npm run build:mac && npm run build:linux",
    "postinstall": "electron-builder install-app-deps",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"main/**/*.ts\" \"renderer/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"main/**/*.ts\" \"renderer/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "dotenv": "^17.3.1",
    "electron-is-dev": "^3.0.1",
    "electron-log": "^5.4.4",
    "electron-serve": "^1.3.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.52",
    "autoprefixer": "^10.4.19",
    "electron": "^34.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.5.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-junit": "^17.0.0",
    "next": "^14.2.4",
    "nextron": "^9.5.0",
    "postcss": "^8.4.38",
    "prettier": "^3.9.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.0.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.65.0"
  },
  "jest": {
    "projects": [
      {
        "displayName": "main",
        "testEnvironment": "node",
        "testMatch": [
          "<rootDir>/main/**/*.spec.ts"
        ],
        "transform": {
          "^.+\\.ts$": [
            "ts-jest",
            {
              "tsconfig": "<rootDir>/tsconfig.jest.json"
            }
          ]
        },
        "moduleFileExtensions": [
          "ts",
          "js",
          "json"
        ]
      },
      {
        "displayName": "renderer",
        "testEnvironment": "jsdom",
        "testMatch": [
          "<rootDir>/renderer/**/*.spec.ts"
        ],
        "transform": {
          "^.+\\.ts$": [
            "ts-jest",
            {
              "tsconfig": "<rootDir>/tsconfig.jest.json"
            }
          ]
        },
        "moduleFileExtensions": [
          "ts",
          "js",
          "json"
        ]
      }
    ],
    "collectCoverageFrom": [
      "main/**/*.ts",
      "renderer/lib/**/*.ts",
      "!**/*.d.ts",
      "!**/*.spec.ts"
    ],
    "coverageDirectory": "coverage"
  }
}
